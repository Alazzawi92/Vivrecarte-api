PORT=5000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=vivrecard_db
DB_SSL=false

JWT_SECRET=change_this_super_secret
CLIENT_URL=http://localhost:5000

MAIL_ENABLED=false

# SMTP provider: resend or brevo
MAIL_PROVIDER=resend

# Resend SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=replace_with_resend_api_key
SMTP_SENDER=no-reply@example.com

# Brevo SMTP (used when MAIL_PROVIDER=brevo)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=replace_with_brevo_user
BREVO_SMTP_PASS=replace_with_brevo_pass
BREVO_SMTP_SENDER=no-reply@example.com
